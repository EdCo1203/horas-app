# === Configuración del servidor ===
PORT=4000

# === Seguridad ===
# Cambiá esto por una cadena larga y aleatoria en producción.
# Generá una con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# === Airtable (lectura del personal) ===
# El personal se sincroniza directo desde Airtable con el botón "Sincronizar".
# Las horas se siguen subiendo por CSV. Airtable es SOLO LECTURA.
#
# 1) Token: creá un Personal Access Token en https://airtable.com/create/tokens
#    con permiso 'data.records:read' (solo lectura) sobre tu base.
# 2) Base ID: es la parte que empieza con 'app...' en la URL de tu base:
#    https://airtable.com/appXXXXXXXXXXXXXX/...  ->  appXXXXXXXXXXXXXX
# 3) Tabla: el nombre exacto de la tabla de personal (ej. "Cuentas de Glovo").
# 4) Vista: el nombre exacto de la vista a leer (respetá mayúsculas y acentos).
#    Dejalo vacío para traer todos los registros de la tabla.
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Cuentas de Glovo
AIRTABLE_VIEW=
# Gestor fijo para esta base (opcional): si la base NO tiene campo de gestor,
# se le asigna este gestor a todos sus riders. Dejalo vacío si la base ya trae gestor.
AIRTABLE_GESTOR=

# --- Segunda base de Airtable (otras ciudades) ---
# Si manejás el personal en más de una base con la misma estructura, agregá acá
# la segunda. El sistema junta el personal de todas en una sola lista al sincronizar.
# Si el mismo token tiene acceso a las dos bases, no hace falta repetir el token
# (dejá AIRTABLE_TOKEN_2 vacío y usa el de arriba). Podés agregar más con _3, _4, …
AIRTABLE_BASE_ID_2=
AIRTABLE_TABLE_2=Cuentas De Riders
AIRTABLE_VIEW_2=
AIRTABLE_TOKEN_2=
# Gestor fijo para la segunda base (ej. Rayo). Esta base no trae gestor, así que
# todos sus riders quedan bajo este gestor para el control de acceso.
AIRTABLE_GESTOR_2=

# === Credenciales iniciales de los 2 admins ===
# Se usan solo la primera vez, al inicializar la base (npm run init-db).
ADMIN1_EMAIL=admin1@empresa.com
ADMIN1_PASSWORD=Admin1_2026!
ADMIN2_EMAIL=admin2@empresa.com
ADMIN2_PASSWORD=Admin2_2026!
